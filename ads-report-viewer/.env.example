# ──────────────────────────────────────────────
# Ads Report Viewer — Environment Variables
# Copy this file to .env.local and fill in values
# ──────────────────────────────────────────────

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/ads_report_viewer"

# JWT Secret (min 32 chars, random string)
JWT_SECRET="change-this-to-a-very-long-random-secret-key-min-32-chars"

# Google Service Account JSON (paste full JSON as single line, or use file path)
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}'

# Telegram Bot
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"
TELEGRAM_BOT_USERNAME="your_bot_username_here"   # without @, e.g. my_ads_bot
TELEGRAM_WEBHOOK_SECRET="optional-secret-for-webhook-verification"

# Cron job secret (to protect /api/cron/update endpoint)
CRON_SECRET="change-this-cron-secret"

# App settings
NEXT_PUBLIC_APP_NAME="Ads Report Viewer"
NODE_ENV="development"
